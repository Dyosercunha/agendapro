{
  "redirects": [
    {
      "source": "/:slug((?!.*\\.)(?!agendamento$|agenda-pro$|api$|assets$|barbearia$|painel$|painel-plataforma$|plataforma$)[^/]+)",
      "destination": "/agendamento/:slug",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/og/:slug",
      "destination": "/api/og?slug=:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
